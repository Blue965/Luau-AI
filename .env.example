# Copie en .env et remplis au moins UNE clé API.

# Groq — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Gratuit (limité) : OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=http://localhost

# Hugging Face (secours)
HUGGINGFACE_API_KEY=
